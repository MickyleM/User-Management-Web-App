@using BlazorApp.Services
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthService AuthService

@if(IsVisible){
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-card" @onclick:stopPropagation="true">
            
            <div class="modal-header">
                <h3>New Ex-Member Record</h3>
                <button type="button" @onclick="Close">&times;</button>
            </div>

            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group full-width">
                        <label>Name</label>
                        <input type="text" @oninput="e=> model.name = e.Value.ToString()" placeholder="John Doe"/>
                    </div>
                    <div class="form-group">
                        <label>Constable Number</label>
                        <input type="text" @oninput="e=> model.consNum = int.Parse(e.Value.ToString())" placeholder="e.g. 1234"/>
                    </div>
                    <div class="form-group">
                        <label>Termination Date</label>
                        <input type="date" @oninput="e=> terminationDate = e.Value.ToString()"/>
                    </div>
                    <div class="form-group">
                        <label>Registration Number</label>
                        <input type="text" @oninput="e=> model.regNum = e.Value.ToString()" placeholder="JCF123"/>
                    </div>
                    <div class="form-group">
                        <label>Rank</label>
                        <input type="text" @oninput="e=> model.rank = e.Value.ToString()" placeholder="Constable"/>
                    </div>
                    <div class="form-group">
                        <label>Last Division</label>
                        <input type="text" @oninput="e=> model.lastDiv = e.Value.ToString()" placeholder="Division"/>
                    </div>
                    <div class="form-group full-width">
                        <label>Termination Reason</label>
                        <input type="text" @oninput="e => model.termReason = e.Value.ToString()" placeholder="Reason for termination" />
                    </div>
                    <div class="form-group">
                        <label>Force Orders Number</label>
                        <input type="text" @oninput="e => model.forceOrdersNum = e.Value.ToString()" placeholder="0000X" />
                    </div>
                </div>

                @if(showError)
                {
                    <p class="error-msg">Please fill in all required fields</p>
                }

            </div>

            <div class="modal-footer">
                <button type="button" @onclick="Close">Cancel</button>
                <button type="button" @onclick="HandleSubmit" class="btn-primary">Save Record</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }

    private ExMember model = new();
    private bool showError = false;
    private string terminationDate = "";

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(model.name))
        {
            showError = true;
            return;
        }

        model.termDate = DateOnly.Parse(terminationDate);
        model.createdOn = DateOnly.FromDateTime(DateTime.Today);
        model.createdBy = AuthService.CurrentUserId;

        DbContext.ExMembers.Add(model);
        await DbContext.SaveChangesAsync();

        model = new();
        await OnSave.InvokeAsync();
        await OnClose.InvokeAsync();
    }

    private async Task Close(){
        showError = false;
        model = new();
        await OnClose.InvokeAsync();
    }
}